{
  "name": "peakcam",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "import-resorts": "ts-node --esm --project tsconfig.scripts.json scripts/import-resorts.ts",
    "import-resorts:standalone": "node scripts/import-resorts-standalone.mjs",
    "agents": "node agents/loop.mjs",
    "agents:dry-run": "node agents/loop.mjs --dry-run",
    "agents:extract-plugins": "for f in plugins/*.plugin; do name=$(basename \"$f\" .plugin); mkdir -p \"agents/plugins/$name\" && unzip -o \"$f\" -d \"agents/plugins/$name\"; done",
    "snotel-sync": "node scripts/snotel-sync.mjs",
    "cam-health": "node scripts/cam-health-check.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "fuse.js": "^7.0.0",
    "leaflet": "^1.9.4",
    "next": "16.1.6",
    "posthog-js": "^1.362.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
