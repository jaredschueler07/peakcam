# ─────────────────────────────────────────────────────────────
# PeakCam — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# Supabase — find these in: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — used by import script + cron jobs ONLY
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# MapTiler — dark terrain tiles for the interactive map
# Sign up free at https://cloud.maptiler.com/ (300k sessions/mo free)
# Without this key, the map falls back to Carto Dark Matter (flat, no terrain).
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-api-key-here

# Site URL — used for email links and cron scripts
# In production, set to your deployed URL (e.g. https://peakcam.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Powder Alerts — Resend email service
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=re_xxxxxxxxxxxx

# Powder Alerts — Cron trigger authentication
# Generate a random secret (e.g. openssl rand -hex 32) to protect the trigger endpoint
CRON_SECRET=your-random-secret-here

# ─── Cam reports ──────────────────────────────────────────────
# Who receives the "cam reported broken" notification emails.
# Falls back to ALERT_ADMIN_EMAIL, then to the hardcoded default.
CAM_REPORT_ADMIN_EMAIL=

# Salt used for daily-rotating SHA-256 IP hashing (abuse triage only).
# Optional — if unset, ip_hash is left NULL.
CAM_REPORT_SALT=
